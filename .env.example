# ============================================================
# SAGUARO CRM - ENVIRONMENT CONFIGURATION
# ============================================================
#
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
#
# cp .env.example .env.local
#

# ============================================================
# SUPABASE CONFIGURATION (required)
# ============================================================
# Get these from: https://app.supabase.com → Project Settings
#
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Server-side only (store securely, never expose to client)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: PostgreSQL connection for direct access (if needed)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres


# ============================================================
# QUICKBOOKS INTEGRATION (required for Phase 1)
# ============================================================
# Get these from: https://developer.intuit.com → Your App → Settings
# Client ID: Public identifier for your app
# Client Secret: Keep secure! Never commit or expose
# Redirect URI: Must match exactly in QB app settings
#
QUICKBOOKS_CLIENT_ID=ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnop
QUICKBOOKS_CLIENT_SECRET=your_incredibly_long_secret_key_from_intuit_here

# Development and production versions
QUICKBOOKS_REDIRECT_URI_DEV=http://localhost:3000/api/integrations/quickbooks/callback
QUICKBOOKS_REDIRECT_URI_PROD=https://yourdomain.com/api/integrations/quickbooks/callback

# Use appropriate URI based on environment
QUICKBOOKS_REDIRECT_URI=${QUICKBOOKS_REDIRECT_URI_DEV}


# ============================================================
# STORAGE CONFIGURATION (required for Phase 1 photos)
# ============================================================
# Supabase Storage bucket name for project photos
#
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=project-photos


# ============================================================
# SLACK INTEGRATION (optional, required for Phase 2)
# ============================================================
# Setup: https://api.slack.com → Create App → Incoming Webhooks
# Each project can have its own webhook URL
#
SLACK_SIGNING_SECRET=your_slack_signing_secret_here
SLACK_BOT_TOKEN=xoxb-your-bot-token-here


# ============================================================
# MICROSOFT TEAMS INTEGRATION (optional, required for Phase 2)
# ============================================================
# Setup: Microsoft Teams → Apps → Connectors → Incoming Webhook
#
TEAMS_WEBHOOK_URL=https://outlook.webhook.office.com/webhookb2/...


# ============================================================
# STRIPE INTEGRATION (optional, required for Phase 3 - Reseller Portal)
# ============================================================
# Get from: https://dashboard.stripe.com → Developers → API Keys
#
STRIPE_PUBLIC_KEY=pk_live_your_public_key_here
STRIPE_SECRET_KEY=sk_live_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here


# ============================================================
# EMAIL SERVICE (optional, for notifications)
# ============================================================
# SendGrid or similar SMTP service
#
SENDGRID_API_KEY=SG.your_sendgrid_key_here
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
EMAIL_FROM_NAME=Saguaro CRM


# ============================================================
# MAPS & GEOLOCATION (optional, required for Phase 3 - Geofencing)
# ============================================================
# Google Maps API or Mapbox
#
NEXT_PUBLIC_GOOGLE_MAPS_KEY=AIzaSyDyWJOw5x-kxHq67ZSqVlVZh0...
# OR
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoieW91cn...


# ============================================================
# AWS S3 / CLOUD STORAGE (optional, for photo backups)
# ============================================================
# Alternative to Supabase Storage
#
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_S3_BUCKET=saguaro-project-photos
AWS_REGION=us-east-1


# ============================================================
# APPLICATION SETTINGS
# ============================================================
#
# Environment type: development, staging, production
NODE_ENV=development

# Enable HTTPS enforcement in production
ENFORCE_HTTPS=true

# API rate limiting (requests per minute)
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# Max file upload size (bytes, default 10MB)
MAX_FILE_UPLOAD_SIZE=10485760

# Session timeout (minutes)
SESSION_TIMEOUT_MINUTES=60

# Enable debug mode (set to false in production)
DEBUG=false


# ============================================================
# LOGGING & MONITORING (optional)
# ============================================================
# Sentry error tracking
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# New Relic APM
NEW_RELIC_LICENSE_KEY=your_new_relic_license_key_here

# LogRocket session replay
NEXT_PUBLIC_LOGROCKET_ID=your_logrocket_id_here


# ============================================================
# FEATURE FLAGS (optional)
# ============================================================
# Control feature availability
#
FEATURE_OFFLINE_SYNC=true
FEATURE_QUICKBOOKS=true
FEATURE_REPORT_BUILDER=true
FEATURE_ALERTS=true
FEATURE_PHOTO_UPLOAD=true
FEATURE_GEOFENCING=false
FEATURE_RESELLER_PORTAL=false


# ============================================================
# DATABASE SETTINGS (production)
# ============================================================
# For hosted Supabase, use the connection pool endpoint
#
DATABASE_HOST=db.xxxxx.supabase.co
DATABASE_PORT=5432
DATABASE_NAME=postgres
DATABASE_USER=postgres
DATABASE_PASSWORD=your_secure_password_here
DATABASE_SSL=true
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10


# ============================================================
# SECURITY SETTINGS
# ============================================================
#
# JWT Secret (for signing tokens - must be secure and unique)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com,https://www.yourdomain.com

# Security timestamp window (seconds)
TIMESTAMP_WINDOW=300

# Password hashing iterations
BCRYPT_ROUNDS=12


# ============================================================
# THIRD PARTY SERVICES
# ============================================================
#
# OCR Provider (for Phase 2 - photo text extraction)
GOOGLE_CLOUD_VISION_KEY=path/to/google-vision-key.json

# SMS notifications (Twilio)
TWILIO_ACCOUNT_SID=ACyour_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Voice calls (Twilio)
TWILIO_VOICE_CAPABILITY_TOKEN=your_voice_token


# ============================================================
# DEPLOYMENT SETTINGS
# ============================================================
#
# Vercel environment (auto-set by Vercel)
VERCEL_ENV=production
VERCEL_URL=https://yourdomain.com

# Or Netlify environment
NETLIFY_CONTEXT=production
NETLIFY_SITE_NAME=your-site-name

# Or custom hosting
HOSTING_PROVIDER=custom
HOSTING_URL=https://yourdomain.com
HOSTING_API_URL=https://api.yourdomain.com
