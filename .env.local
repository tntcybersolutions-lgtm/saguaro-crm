# ============================================================
# SAGUARO CRM — DEMO MODE (Preview without real Supabase)
# Copy this to .env.local to run locally in demo/preview mode.
# The app will use mock data — no real database needed.
# ============================================================

# Demo mode flag — enables mock data throughout the app
NEXT_PUBLIC_DEMO_MODE=true

# Placeholder Supabase values (app won't try to connect in demo mode)
NEXT_PUBLIC_SUPABASE_URL=https://demo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=demo_anon_key_placeholder
SUPABASE_SERVICE_ROLE_KEY=demo_service_role_key_placeholder

# Anthropic — REAL key needed for live AI demos
# Get free at: https://console.anthropic.com (includes free credits)
ANTHROPIC_API_KEY=sk-ant-api03-PASTE_YOUR_KEY_HERE

# Email — leave blank in demo mode (emails print to console instead)
RESEND_API_KEY=
EMAIL_FROM=Saguaro CRM <demo@saguaro.demo>
EMAIL_REPLY_TO=demo@saguaro.demo

# Demo security tokens (any value works in demo mode)
SAGUARO_API_SECRET=demo-secret-not-for-production
AUTOPILOT_CRON_SECRET=demo-cron-secret

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SANDBOX_URL=http://localhost:3000

# Stripe — leave blank in demo mode (billing disabled)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

COMPANY_NAME=Saguaro CRM (Demo)
