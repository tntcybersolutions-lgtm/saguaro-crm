# ============================================================
# SAGUARO CRM — PRODUCTION ENVIRONMENT VARIABLES
# ============================================================
# Copy this to .env.local and fill in ALL values before deploying.
# Add all of these to Vercel → Settings → Environment Variables.
#
# NEVER commit .env.local to git.
# ============================================================

# ────────────────────────────────────────────────────────────
# SUPABASE  (Required — get from app.supabase.com)
# ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ────────────────────────────────────────────────────────────
# ANTHROPIC / CLAUDE AI  (Required)
# Get key: https://console.anthropic.com/settings/keys
# ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ────────────────────────────────────────────────────────────
# STRIPE BILLING  (Required)
# Get keys: https://dashboard.stripe.com/apikeys
# ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
# Get webhook secret: https://dashboard.stripe.com/webhooks → Add endpoint
# Endpoint URL: https://app.saguarocrm.com/api/billing/webhook
# Events to listen for: checkout.session.completed, customer.subscription.updated,
#   customer.subscription.deleted, invoice.payment_succeeded, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...

# ────────────────────────────────────────────────────────────
# EMAIL — RESEND  (Required)
# Sign up: https://resend.com — verify your sending domain first
# ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
# Must match a verified domain in your Resend account
EMAIL_FROM=Saguaro CRM <noreply@mail.yourdomain.com>
EMAIL_REPLY_TO=projects@yourdomain.com
SALES_EMAIL=sales@yourdomain.com
SUPPORT_EMAIL=support@yourdomain.com

# ────────────────────────────────────────────────────────────
# APP URLS  (Required)
# ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.saguarocrm.com
NEXT_PUBLIC_SANDBOX_URL=https://sandbox.saguarocrm.com

# ────────────────────────────────────────────────────────────
# SECURITY SECRETS  (Required — generate with: openssl rand -hex 32)
# ────────────────────────────────────────────────────────────
SAGUARO_API_SECRET=<openssl rand -hex 32>
AUTOPILOT_CRON_SECRET=<openssl rand -hex 32>
JWT_SECRET=<openssl rand -hex 64>

# ────────────────────────────────────────────────────────────
# COMPANY INFO  (Required)
# ────────────────────────────────────────────────────────────
COMPANY_NAME=Saguaro CRM

# ────────────────────────────────────────────────────────────
# WHITE-LABEL PLATFORM  (Required for white-label feature)
# ────────────────────────────────────────────────────────────
WHITE_LABEL_CNAME_TARGET=tenants.saguarocrm.com
# Get from Vercel: https://vercel.com/account/tokens
VERCEL_API_TOKEN=...
# Get from Vercel project settings
VERCEL_PROJECT_ID=prj_...

# ────────────────────────────────────────────────────────────
# CORS  (Optional — defaults to same-origin only)
# Comma-separated list of allowed origins for API routes
# ────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://app.saguarocrm.com,https://sandbox.saguarocrm.com

# ────────────────────────────────────────────────────────────
# QUICKBOOKS INTEGRATION  (Optional)
# ────────────────────────────────────────────────────────────
QB_CLIENT_ID=...
QB_CLIENT_SECRET=...
QB_REDIRECT_URI=https://app.saguarocrm.com/api/integrations/quickbooks/callback
QB_SANDBOX=false

# ────────────────────────────────────────────────────────────
# SLACK INTEGRATION  (Optional)
# ────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# ────────────────────────────────────────────────────────────
# GOOGLE CLOUD VISION  (Optional — for photo OCR)
# ────────────────────────────────────────────────────────────
GOOGLE_CLOUD_VISION_API_KEY=...

# ────────────────────────────────────────────────────────────
# POSTHOG ANALYTICS  (Recommended — server + client tracking)
# Sign up: https://posthog.com — free tier covers most startups.
# ────────────────────────────────────────────────────────────
POSTHOG_API_KEY=phc_YOUR_PROJECT_API_KEY
POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=phc_YOUR_PROJECT_API_KEY
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ────────────────────────────────────────────────────────────
# PRODUCTION SETTINGS
# ────────────────────────────────────────────────────────────
NODE_ENV=production
ENFORCE_HTTPS=true
