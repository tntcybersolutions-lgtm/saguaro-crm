{
  "name": "saguaro-crm",
  "version": "1.0.0",
  "description": "Saguaro CRM - Construction Project Management Platform",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "cap:sync": "cap sync",
    "cap:ios": "cap open ios",
    "cap:android": "cap open android",
    "cap:build:ios": "next build && cap sync ios",
    "cap:build:android": "next build && cap sync android",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,css,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "rm -rf .next node_modules",
    "setup": "npx tsx scripts/run-migrations.ts && npx tsx scripts/setup-storage.ts",
    "setup:storage": "npx tsx scripts/setup-storage.ts",
    "setup:migrations": "npx tsx scripts/run-migrations.ts",
    "verify": "npx tsx scripts/verify-deployment.ts",
    "seed:templates": "curl -X POST $NEXT_PUBLIC_APP_URL/api/documents/seed-templates -H \"Authorization: Bearer $SAGUARO_API_SECRET\"",
    "seed:sandbox": "npx tsx -e \"import('./sandbox-manager').then(m => m.SandboxManager)\"",
    "db:push": "supabase db push",
    "db:pull": "supabase db pull",
    "db:reset": "supabase db reset"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.54.0",
    "@aparajita/capacitor-biometric-auth": "^9.0.0",
    "@capacitor-mlkit/barcode-scanning": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/camera": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/device": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/geolocation": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/local-notifications": "^6.0.0",
    "@capacitor/network": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/push-notifications": "^6.0.0",
    "@capacitor/share": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@capacitor/toast": "^6.0.0",
    "@sentry/nextjs": "^8.55.0",
    "@supabase/auth-helpers-nextjs": "^0.9.0",
    "@supabase/supabase-js": "^2.38.0",
    "@types/react-datepicker": "^6.2.0",
    "date-fns": "^3.3.0",
    "mustache": "^4.2.0",
    "next": "^14.0.0",
    "pdf-lib": "^1.17.1",
    "posthog-js": "^1.360.0",
    "posthog-node": "^4.0.0",
    "puppeteer": "^22.15.0",
    "react": "^18.2.0",
    "react-datepicker": "^9.1.0",
    "react-dom": "^18.2.0",
    "resend": "^4.0.0",
    "sharp": "^0.34.5",
    "stripe": "^17.0.0",
    "swr": "^2.4.1",
    "xlsx": "^0.18.5",
    "zod": "^3.23.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@next/bundle-analyzer": "^14.0.0",
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/mustache": "^4.2.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "axe-core": "^4.7.2",
    "eslint": "^8.50.0",
    "eslint-config-next": "^14.0.0",
    "jest": "^29.7.0",
    "jsdom": "^22.1.0",
    "prettier": "^3.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "keywords": [
    "crm",
    "construction",
    "project-management",
    "offline-sync",
    "quickbooks",
    "invoicing",
    "budget-tracking"
  ],
  "author": "Copper State Developments",
  "license": "PROPRIETARY"
}
